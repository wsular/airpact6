Bootstrap: docker
From: ubuntu

%files
#  /home/airpact/models/MEGANv3.2
#  /home/airpact/models/SMOKEv5.0

%post
###################################################################
  # ....Install compilers and utilities
  apt -y update
  apt -y install build-essential
  apt -y install gfortran

  apt -y install curl
  apt -y install m4
  apt -y install nano
  apt -y install csh
#  apt -y install tcsh
  apt -y install wget
  apt -y install zlib1g zlib1g-dev
  apt -y install libdispatch-dev
  LD_LIBRARY_PATH=/usr/lib:$LD_LIBRARY_PATH
  apt -y install git

  # ....Install wine for MOVES4
  #dpkg --add-architecture i386 && apt-get update && apt-get install wine32
  #apt -y install wine winetricks

  # ....Create shared directories
  mkdir -p /opt/share
  #mkdir -p /opt/share/MEGANv3.2
  #mkdir -p /opt/share/SMOKEv5.0

###################################################################
  # ....Install OpenMPI
  #     Needed by openmpi
  apt -y install autoconf
  apt -y install automake
  apt -y install libtool
  apt -y install flex
  apt -y install pandoc

  cd /opt/share
  wget https://download.open-mpi.org/release/open-mpi/v4.1/openmpi-4.1.4.tar.gz
  tar xvfz openmpi-4.1.4.tar.gz
  cd openmpi-4.1.4
  ./configure --prefix=/usr/local
  make all install
  LD_LIBRARY_PATH=/usr/local/lib:$LD_LIBRARY_PATH

###################################################################
  # ....Install the netCDF libraries
  export CC=gcc
  export FC=gfortran
  export NCDIR=/usr/local
  export LD_LIBRARY_PATH=${NCDIR}/lib:${LD_LIBRARY_PATH}

  #         netcdf-c; version used by CMAS
  # Flags set in Makeinclude.Linux2_x86_64gfort10
  #     ....See Environmental Variable Description Notes at https://docs.unidata.ucar.edu/netcdf-c/current/building_netcdf_fortran.html
  #
  # MFLAGS    = -ffast-math -funroll-loops -m64  #  -Wall -Wsurprising -march=native -mtune=native
  #
  # COPTFLAGS = -O3 ${MFLAGS}
  # FOPTFLAGS = -O3 -fallow-argument-mismatch ${MFLAGS}
  # FPPFLAGS  = -DF90=1
  # FSFLAGS   = -fno-automatic
  # ARCHFLAGS = \
  #  -DAUTO_ARRAYS=1 \
  #  -DF90=1 -DFLDMN=1 \
  #  -DFSTR_L=int \
  #  -DIOAPI_NO_STDOUT=1 \
  #  -DNEED_ARGS=1
  # PARFLAGS  =
  # ARCHLIB   = -dynamic -L/usr/lib64 -lm -lpthread -lc

  export CFLAGS='-O3 -ffast-math -funroll-loops -m64'
  export FCFLAGS='-O3 -ffast-math -funroll-loops -m64 -fallow-argument-mismatch -fno-automatic -DAUTO_ARRAYS=1 -DF90=1 -DFLDMN=1 -DFSTR_L=int -DIOAPI_NO_STDOUT=1 -DNEED_ARGS=1'

  cd /opt/share
  wget https://github.com/Unidata/netcdf-c/archive/refs/tags/v4.8.1.tar.gz
  tar xvf v4.8.1.tar.gz
  cd netcdf-c-4.8.1
  ./configure --prefix=${NCDIR} --disable-netcdf-4 --disable-dap --disable-nczarr
  make check install

  #         netcdf-fortran; version used by CMAS
  cd /opt/share
  wget https://github.com/Unidata/netcdf-fortran/archive/refs/tags/v4.5.4.tar.gz
  tar xvf v4.5.4.tar.gz
  cd netcdf-fortran-4.5.4
  export LD_LIBRARY_PATH=${NCDIR}/lib:${LD_LIBRARY_PATH}
  export NFDIR=/usr/local
  export CPPFLAGS='-I${NCDIR}/include'
  export LDFLAGS='-L${NCDIR}/lib'
  export LIBS='-lnetcdf'
  ./configure --disable-shared --prefix=${NFDIR} --disable-fortran-type-check
  make check install
  ldconfig
  
###################################################################
  # ....Clone repos for building CMAQ

  #         airpact6; contains customized Makefiles
  cd /opt/share
  git clone https://github.com/wsular/airpact6.git

  #         IOapi v3.2
  git clone https://github.com/cjcoats/ioapi-3.2.git

  #         CMAQ v5.4
  git clone -b main https://github.com/USEPA/CMAQ.git

###################################################################
  #     Make and Install CMAQ v5.4
#  cp /opt/share/airpact6/dev/apptainer/scripts/cmaq-5.4.csh .
#  chmod ugo+x cmaq-5.4.csh
#  ./cmaq-5.4.csh > cmaq-5.4.log

  # ....Update links to shared libraries
  ldconfig
